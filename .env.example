# =============================================================================
# ExamEdge — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://examedge_user:your_password@localhost:5432/examedge_db"
DIRECT_URL="postgresql://examedge_user:your_password@localhost:5432/examedge_db"
# DIRECT_URL is used by Prisma Migrate (bypasses PgBouncer in production)

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="replace-with-32-char-random-string-1"
JWT_REFRESH_SECRET="replace-with-32-char-random-string-2"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ── MSG91 (OTP via SMS) ───────────────────────────────────────────────────────
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_TEMPLATE_ID="your-otp-template-id"
MSG91_SENDER_ID="EXAMEG"

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="examedge-assets"
AWS_S3_BASE_URL="https://examedge-assets.s3.ap-south-1.amazonaws.com"

# ── Email (Nodemailer / SMTP) ─────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="noreply@examedge.in"
SMTP_PASSWORD="your-smtp-app-password"
EMAIL_FROM="ExamEdge <noreply@examedge.in>"

# ── Super Admin Seed ──────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL="superadmin@examedge.in"
SUPER_ADMIN_PASSWORD="ChangeThisImmediately@123"

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"
SUPER_ADMIN_URL="http://localhost:3003"
API_VERSION="v1"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
